{
    "name": "codemonster-ru/auth",
    "description": "Framework-agnostic authentication primitives for Annabel applications.",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../*",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "homepage": "https://github.com/codemonster-ru/auth",
    "authors": [
        {
            "name": "Kirill Kolesnikov",
            "email": "admin@codemonster.net",
            "homepage": "https://github.com/KolesnikovKirill",
            "role": "Lead Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Codemonster\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codemonster\\Auth\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "codemonster-ru/database": "^2.0",
        "codemonster-ru/http": "^2.1",
        "codemonster-ru/session": "^2.0.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0 || ^12.0"
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=1G",
        "test": "phpunit --colors=always --testdox"
    },
    "keywords": [
        "php",
        "auth",
        "authentication",
        "session",
        "annabel",
        "codemonster"
    ],
    "support": {
        "issues": "https://github.com/codemonster-ru/auth/issues",
        "source": "https://github.com/codemonster-ru/auth"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
