#!/usr/bin/env php
<?php

use Codemonster\Env\Env;
use Codemonster\Database\CLI\DatabaseCLIKernel;
use Codemonster\Database\CLI\Commands\MakeMigrationCommand;
use Codemonster\Database\CLI\Commands\MakeSeedCommand;
use Codemonster\Database\Migrations\MigrationPathResolver;
use Codemonster\Database\Seeders\SeedPathResolver;
use Codemonster\Annabel\Application;

require __DIR__ . '/../vendor/autoload.php';

$argv = $_SERVER['argv'] ?? [];
$command = $argv[1] ?? null;

$envFile = __DIR__ . '/../.env';

if (is_file($envFile)) {
    Env::load($envFile);
}

$configPath = __DIR__ . '/../config/database.php';

if (is_file($configPath)) {
    /** @var array<string, mixed> $databaseConfig */
    $databaseConfig = require $configPath;
} else {
    $databaseConfig = [
        'default' => 'mysql',
        'connections' => [
            'mysql' => [
                'host' => '127.0.0.1',
                'port' => 3306,
                'database' => 'test',
                'username' => 'root',
                'password' => '',
                'charset' => 'utf8mb4',
            ],
        ],
    ];
}

$module = null;

if ($command === 'make:migration' || $command === 'make:seed') {
    for ($i = 2; $i < count($argv); $i++) {
        $arg = $argv[$i];

        if ($arg === '--module') {
            $module = $argv[$i + 1] ?? null;

            break;
        }

        if (is_string($arg) && str_starts_with($arg, '--module=')) {
            $module = substr($arg, strlen('--module='));

            break;
        }
    }

    if (is_string($module) && $module !== '') {
        $moduleBase = __DIR__ . '/../app/Modules/' . $module;
        $modulePath = $moduleBase . '/database/migrations';
        $moduleSeedPath = $moduleBase . '/database/seeds';

        if (!is_dir($moduleBase)) {
            fwrite(STDERR, "Unknown module: {$module}\n");

            exit(1);
        }

        $databaseConfig['migrations']['paths'] ??= [];

        array_unshift($databaseConfig['migrations']['paths'], $modulePath);

        $databaseConfig['seeds']['paths'] ??= [];

        array_unshift($databaseConfig['seeds']['paths'], $moduleSeedPath);
    }
}

$paths = new MigrationPathResolver();
$configPaths = $databaseConfig['migrations']['paths'] ?? [];

if (is_string($configPaths)) {
    $configPaths = [$configPaths];
}

if (is_iterable($configPaths)) {
    foreach ($configPaths as $path) {
        $paths->addPath((string)$path);
    }
}

if (empty($paths->getPaths())) {
    $paths->addPath(__DIR__ . '/../database/migrations');
}

$seedPaths = new SeedPathResolver();
$configSeedPaths = $databaseConfig['seeds']['paths'] ?? [];

if (is_string($configSeedPaths)) {
    $configSeedPaths = [$configSeedPaths];
}

if (is_iterable($configSeedPaths)) {
    foreach ($configSeedPaths as $path) {
        $seedPaths->addPath((string)$path);
    }
}

if (empty($seedPaths->getPaths())) {
    $seedPaths->addPath(__DIR__ . '/../database/seeds');
}

// `make:*` does not require a database connection. Avoid failing on missing DB.
if ($command === 'make:migration' || $command === 'make:seed') {
    $filtered = [];

    for ($i = 2; $i < count($argv); $i++) {
        $arg = $argv[$i];

        if ($arg === '--module') {
            $i++;

            continue;
        }

        if (is_string($arg) && str_starts_with($arg, '--module=')) {
            continue;
        }

        $filtered[] = $arg;
    }

    if ($command === 'make:migration') {
        $make = new MakeMigrationCommand($paths);

        exit($make->handle($filtered));
    }

    $make = new MakeSeedCommand($seedPaths);

    exit($make->handle($filtered));
}

// For migrate/rollback/status, bootstrap the Annabel application so global helpers like `app()` / `schema()`
// are available inside migrations, and so the migrator/repository use the same connection.
$bootstrapFile = __DIR__ . '/../bootstrap/app.php';
$app = is_file($bootstrapFile) ? require $bootstrapFile : null;

if (!$app instanceof Application) {
    $app = new Application(__DIR__ . '/..');
}

try {
    /** @var DatabaseCLIKernel $kernel */
    $kernel = $app->make(DatabaseCLIKernel::class);
} catch (\Throwable $e) {
    fwrite(STDERR, "Database CLI bootstrap failed: " . $e->getMessage() . PHP_EOL);

    exit(1);
}

exit($kernel->handle($argv));
