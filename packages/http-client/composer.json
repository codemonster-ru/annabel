{
    "name": "codemonster-ru/http-client",
    "description": "Lightweight HTTP client for Annabel applications.",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../*",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "homepage": "https://github.com/codemonster-ru/http-client",
    "authors": [
        {
            "name": "Kirill Kolesnikov",
            "email": "admin@codemonster.net",
            "homepage": "https://github.com/KolesnikovKirill",
            "role": "Lead Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Codemonster\\HttpClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codemonster\\HttpClient\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0 || ^12.0"
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=1G",
        "test": "phpunit --colors=always --testdox"
    },
    "keywords": [
        "php",
        "http-client",
        "api",
        "annabel",
        "codemonster"
    ],
    "support": {
        "issues": "https://github.com/codemonster-ru/http-client/issues",
        "source": "https://github.com/codemonster-ru/http-client"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
