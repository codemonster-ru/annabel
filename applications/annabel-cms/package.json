{
  "name": "@codemonster-ru/annabel-cms",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:admin && npm run build:setup",
    "build:admin": "vite build --config app/Modules/Admin/vite.config.js",
    "build:setup": "vite build --config app/Modules/Setup/vite.config.js",
    "dev:admin": "vite --config app/Modules/Admin/vite.config.js --host 0.0.0.0",
    "dev:setup": "vite --config app/Modules/Setup/vite.config.js --host 0.0.0.0"
  },
  "dependencies": {
    "@codemonster-ru/vueforge-core": "^1.30.0",
    "@codemonster-ru/vueforge-layouts": "^1.17.0",
    "@vitejs/plugin-vue": "6.0.7",
    "vite": "8.0.16",
    "vue": "3.5.35"
  }
}
