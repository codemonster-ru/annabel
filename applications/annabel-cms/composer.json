{
    "name": "codemonster-ru/annabel-cms",
    "description": "Official modular CMS built on the Annabel framework",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "annabel",
        "cms",
        "codemonster",
        "framework",
        "php"
    ],
    "require": {
        "php": ">=8.2",
        "codemonster-ru/annabel": "^1.15",
        "codemonster-ru/database": "^2.1",
        "codemonster-ru/http": "^2.1",
        "codemonster-ru/security": "^1.1",
        "codemonster-ru/session": "^2.0",
        "codemonster-ru/view": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Codemonster\\Cms\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Kirill Kolesnikov",
            "email": "admin@codemonster.net",
            "homepage": "https://codemonster.net",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/codemonster-ru/annabel/issues",
        "source": "https://github.com/codemonster-ru/annabel"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "archive": {
        "exclude": [
            "/composer.dev.json",
            "/phpstan.neon.dist",
            "/phpstan-bootstrap.php",
            "/phpunit.xml.dist",
            "/stubs",
            "/tests"
        ]
    }
}
