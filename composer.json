{
    "name": "codemonster-ru/annabel-monorepo",
    "description": "Annabel framework and Codemonster PHP ecosystem monorepo",
    "type": "project",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "canonical": false,
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0 || ^12.0"
    },
    "scripts": {
        "test:framework": "cd packages/framework && ../../vendor/bin/phpunit --testdox",
        "test": "@test:framework"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
