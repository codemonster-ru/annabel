{
    "name": "codemonster-ru/annabel-cms",
    "description": "Official modular CMS built on the Annabel framework",
    "type": "project",
    "license": "MIT",
    "keywords": [
        "annabel",
        "cms",
        "codemonster",
        "framework",
        "php"
    ],
    "require": {
        "php": ">=8.2",
        "codemonster-ru/annabel": "^1.15",
        "codemonster-ru/database": "^2.1",
        "codemonster-ru/http": "^2.1",
        "codemonster-ru/security": "^1.1",
        "codemonster-ru/session": "^2.0",
        "codemonster-ru/view": "^2.3"
    },
    "autoload": {
        "psr-4": {
            "Codemonster\\Cms\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Codemonster\\Cms\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "npm run build:admin && phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "analyse": "@php -d memory_limit=512M vendor/bin/phpstan analyse --debug --no-progress"
    },
    "authors": [
        {
            "name": "Kirill Kolesnikov",
            "email": "admin@codemonster.net",
            "homepage": "https://codemonster.net",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/codemonster-ru/annabel/issues",
        "source": "https://github.com/codemonster-ru/annabel"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    }
}
