APP_DEBUG=false

DB_HOST=db
DB_PORT=3306
DB_DATABASE=annabel_cms
DB_USERNAME=annabel_cms
DB_PASSWORD=annabel_cms

# Use "file" for one application node and "redis" for multiple nodes.
SESSION_DRIVER=file
SESSION_PATH=/app/storage/sessions
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=Lax
SESSION_COOKIE_LIFETIME=86400

SESSION_REDIS_HOST=redis
SESSION_REDIS_PORT=6379
SESSION_REDIS_DATABASE=0
SESSION_REDIS_PREFIX=annabel_cms_session:
SESSION_REDIS_TTL=86400

# Generate with: php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
SESSION_ENCRYPTION_KEY=
SESSION_PREVIOUS_ENCRYPTION_KEY=
SESSION_ALLOW_PLAINTEXT=false
